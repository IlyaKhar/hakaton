# Database configuration
DB_HOST=localhost
DB_PORT=5433
DB_USER=subs
DB_PASSWORD=your_db_password_here
DB_NAME=subs

# Server configuration
PORT=3001
BASE_URL=http://localhost:3001

# JWT secrets (generate strong random strings, минимум 32 символа)
JWT_SECRET=your_jwt_secret_here_min_32_chars
REFRESH_SECRET=your_refresh_secret_here_min_32_chars

# SMTP configuration (optional - for password reset emails)
# Если не настроено - код будет логироваться в консоль (режим разработки(терминал))

# Mail.ru 
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=your-email@mail.ru
SMTP_PASSWORD=your-app-password  # Пароль приложения из настроек Mail.ru
SMTP_FROM=your-email@mail.ru

# Yandex
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=your-email@yandex.ru
# SMTP_PASSWORD=your-app-password  # Пароль приложения из id.yandex.ru/security/app-passwords
# SMTP_FROM=your-email@yandex.ru

# Gmail (требует пароль приложения)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password  # Пароль приложения из myaccount.google.com/apppasswords
# SMTP_FROM=your-email@gmail.com

# Режим разработки (без SMTP)

# Оставь SMTP_* пустыми - код восстановления будет в логах консоли
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# OAuth: Mail.ru
# Подставьте свои ключи Mail.ru OAuth при проверке
MAILRU_CLIENT_ID=replace_with_mailru_client_id
MAILRU_CLIENT_SECRET=replace_with_mailru_client_secret

# OAuth: Gmail
# Redirect URI:
#   http://localhost:3000/api/v1/sources/oauth/gmail/callback
GMAIL_CLIENT_ID=replace_with_gmail_client_id
GMAIL_CLIENT_SECRET=replace_with_gmail_client_secret

# OAuth: Yandex (опционально)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=